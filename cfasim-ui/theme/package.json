{
  "name": "@cfasim-ui/theme",
  "version": "0.3.14",
  "type": "module",
  "description": "CSS theming system for cfasim-ui",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/CDCgov/cfa-simulator.git",
    "directory": "cfasim-ui/theme"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src"
  ],
  "sideEffects": [
    "*.css",
    "./src/all.js"
  ],
  "exports": {
    ".": "./src/cfasim.css",
    "./all": "./src/all.js",
    "./base.css": "./src/base.css",
    "./theme.css": "./src/theme.css",
    "./utilities.css": "./src/utilities.css",
    "./themes/cdc.css": "./src/themes/cdc.css"
  },
  "dependencies": {
    "@cfasim-ui/charts": "workspace:*",
    "@cfasim-ui/components": "workspace:*"
  }
}
